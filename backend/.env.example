# ── RupeeRadar Configuration ──
# Copy this file to .env and fill in your values.
# cp backend/.env.example backend/.env

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# ── Database ──
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./rupeeradar.db
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rupeeradar

# ── AI / LLM Provider ──
# Options: groq, openai, local
# "local" uses lightweight models (free, no API key needed)
# "groq" uses Groq's API (fast, free tier available)
# "openai" uses OpenAI's API (requires paid credits)
LLM_PROVIDER=groq

# Groq API (if LLM_PROVIDER=groq)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── AI Processing Tuning ──
AI_CATEGORIZATION_BATCH_SIZE=15
AI_CONFIDENCE_THRESHOLD=0.9
AI_TIMEOUT_SECONDS=30

# ── File Upload ──
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=[".csv",".pdf"]
UPLOAD_DIR=uploads

# ── Job Processing ──
JOB_TIMEOUT_SECONDS=300
JOB_CLEANUP_TTL_SECONDS=3600
JOB_POLL_INTERVAL_SECONDS=2
