# ── RupeeRadar Frontend — Environment Variables ──
# Copy this file to .env for local development.
# For production (Vercel), set these in the Vercel dashboard.

# REQUIRED for production on Vercel
# Points the frontend to your Railway backend API.
# After deploying your backend on Railway, get its URL and set this:
# VITE_API_URL=https://your-app-name.up.railway.app/api
#
# For local development, the Vite proxy (vite.config.ts) handles /api -> localhost:8000,
# so this can be left empty.
VITE_API_URL=
